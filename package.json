{
  "name": "expo-agent-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace for Expo Agent UI, a semantic agent-control layer for Expo React Native apps.",
  "license": "MIT",
  "packageManager": "npm@11.9.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulnekrasov/swiftui-parser.git"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "workspaces": [
    "packages/core",
    "packages/expo-plugin",
    "packages/mcp-server",
    "packages/cli",
    "packages/example-app"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "overrides": {
    "@expo/metro-config@55.0.17": {
      "postcss": "8.5.12"
    },
    "jest-environment-jsdom@29.7.0": {
      "jsdom": "23.2.0"
    },
    "xcode@3.0.1": {
      "uuid": "14.0.0"
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.14",
    "expo": "~55.0.18",
    "jest-expo": "~55.0.16",
    "typescript": "^5.9.2"
  }
}
