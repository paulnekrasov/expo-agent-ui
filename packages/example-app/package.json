{
  "name": "@agent-ui/example-app",
  "version": "0.0.0",
  "private": true,
  "description": "Expo SDK 55 example app shell for Expo Agent UI.",
  "scripts": {
    "start": "expo start",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "expo export --platform android --output-dir .tmp-review/android-export",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@agent-ui/core": "0.0.0",
    "expo": "~55.0.18",
    "expo-asset": "~55.0.16",
    "react": "19.2.0",
    "react-native": "0.83.6"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "babel-preset-expo": "~55.0.18",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "react-test-renderer": "^19.2.0",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "jest-environment-jsdom": {
      "jsdom": "23.2.0"
    }
  }
}
